<header class="fixed top-0 left-0 right-0 z-[100] transition-all duration-500 bg-white/70 backdrop-blur-md border-b border-gray-100" id="main-header">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
        <a href="/" class="text-2xl font-bold text-emerald-dark flex items-center gap-3 group">
            <div class="w-10 h-10 bg-emerald-dark rounded-xl flex items-center justify-center text-white shadow-lg shadow-emerald-900/10">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                </svg>
            </div>
            <span class="tracking-tight">GreenLife</span>
        </a>

        <nav class="hidden lg:flex items-center gap-8">
            <a href="/" class="text-gray-600 hover:text-emerald-dark font-semibold transition-colors">Trang chủ</a>
            <a href="/shop" class="text-gray-600 hover:text-emerald-dark font-semibold transition-colors">Cửa hàng</a>
            <a href="/about" class="text-gray-600 hover:text-emerald-dark font-semibold transition-colors">Về chúng tôi</a>
            <a href="/contact" class="text-gray-600 hover:text-emerald-dark font-semibold transition-colors">Liên hệ</a>
        </nav>

        <div class="flex items-center gap-5">
            <button class="p-2 text-gray-500 hover:text-emerald-dark transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
            </button>

            <div class="relative group">
                <a href="/cart" class="p-2 text-gray-500 hover:text-emerald-dark transition-colors relative block">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                    </svg>
                    <span class="absolute top-0 right-0 w-5 h-5 bg-emerald-600 text-white text-[10px] flex items-center justify-center rounded-full border-2 border-white">2</span>
                </a>
                
                <!-- Mini Cart Dropdown -->
                <div class="absolute top-full right-0 mt-2 w-80 bg-white rounded-2xl shadow-2xl border border-gray-100 hidden group-hover:block transition-all duration-300 overflow-hidden z-50">
                    <div class="p-5 border-b border-gray-50 flex justify-between items-center">
                        <span class="font-bold">Giỏ hàng</span>
                        <span class="text-xs text-gray-400">2 sản phẩm</span>
                    </div>
                    <div class="max-h-60 overflow-y-auto p-4 space-y-4">
                        <div class="flex items-center gap-4">
                            <div class="w-14 h-14 bg-gray-50 rounded-xl overflow-hidden">
                                <img src="https://images.unsplash.com/photo-1599591037488-dc79493956a2?q=80&w=500" class="w-full h-full object-cover">
                            </div>
                            <div class="flex-1">
                                <div class="font-bold text-sm">Cây Lưỡi Hổ</div>
                                <div class="text-emerald-600 font-bold">150.000đ</div>
                            </div>
                        </div>
                    </div>
                    <div class="p-5 bg-gray-50">
                        <a href="/cart" class="btn-primary w-full py-3">Thanh toán ngay</a>
                    </div>
                </div>
            </div>

            <a href="/auth/login" class="hidden sm:block text-gray-600 hover:text-emerald-dark font-semibold">Đăng nhập</a>
            <button class="btn-primary hidden sm:flex px-6 py-2.5">Bắt đầu</button>
            
            <button class="lg:hidden p-2 text-gray-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
                </svg>
            </button>
        </div>
    </div>
</header>

<script>
    window.addEventListener('scroll', () => {
        const header = document.getElementById('main-header');
        if (window.scrollY > 20) {
            header.classList.add('shadow-sm', 'py-1');
            header.classList.remove('py-0');
        } else {
            header.classList.remove('shadow-sm', 'py-1');
        }
    });
</script>




<script src="/js/search.js"></script>
