<section class="py-12 px-8 max-w-7xl mx-auto">
    <nav class="flex mb-8 text-sm text-gray-500" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2">
            <li><a href="/" class="hover:text-emerald-dark">Trang chủ</a></li>
            <li><svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 5l7 7-7 7" /></svg></li>
            <li><a href="/shop" class="hover:text-emerald-dark">Cửa hàng</a></li>
            <li><svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M9 5l7 7-7 7" /></svg></li>
            <li class="font-semibold text-gray-900"><%= product.name %></li>
        </ol>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Image Gallery -->
        <div class="space-y-4">
            <div class="aspect-square bg-white rounded-[2rem] overflow-hidden shadow-sm">
                <img src="<%= product.imageUrl %>" alt="<%= product.name %>" class="w-full h-full object-cover">
            </div>
            <div class="grid grid-cols-4 gap-4">
                <div class="aspect-square bg-white rounded-2xl overflow-hidden cursor-pointer border-2 border-emerald-dark">
                    <img src="<%= product.imageUrl %>" class="w-full h-full object-cover">
                </div>
                <!-- Mock thumbs -->
                <div class="aspect-square bg-emerald-50 rounded-2xl flex items-center justify-center text-emerald-200">🌿</div>
                <div class="aspect-square bg-emerald-50 rounded-2xl flex items-center justify-center text-emerald-200">🌿</div>
                <div class="aspect-square bg-emerald-50 rounded-2xl flex items-center justify-center text-emerald-200">🌿</div>
            </div>
        </div>

        <!-- Product Info -->
        <div class="flex flex-col justify-center">
            <span class="inline-block px-4 py-1 rounded-full bg-emerald-100 text-emerald-700 text-sm font-bold mb-4 w-fit">
                <%= product.category %>
            </span>
            <h1 class="text-5xl font-bold mb-4"><%= product.name %></h1>
            <p class="text-3xl font-bold text-emerald-dark mb-8"><%= product.price.toLocaleString('vi-VN') %>đ</p>
            
            <p class="text-gray-600 mb-10 leading-relaxed">
                Một loại cây tuyệt vời để làm bừng sáng không gian của bạn. Không chỉ mang lại vẻ đẹp tự nhiên, <%= product.name %> còn giúp thanh lọc không khí và giảm căng thẳng sau những giờ làm việc mệt mỏi.
            </p>

            <!-- Smart Care Indicators -->
            <div class="grid grid-cols-3 gap-4 mb-10">
                <div class="glass p-4 text-center">
                    <div class="text-2xl mb-1">☀️</div>
                    <div class="text-xs font-bold uppercase text-gray-500 mb-1">Ánh sáng</div>
                    <div class="font-semibold"><%= product.light %></div>
                </div>
                <div class="glass p-4 text-center">
                    <div class="text-2xl mb-1">💧</div>
                    <div class="text-xs font-bold uppercase text-gray-500 mb-1">Tưới nước</div>
                    <div class="font-semibold"><%= product.water %></div>
                </div>
                <div class="glass p-4 text-center">
                    <div class="text-2xl mb-1">🌡️</div>
                    <div class="text-xs font-bold uppercase text-gray-500 mb-1">Nhiệt độ</div>
                    <div class="font-semibold">18°C - 28°C</div>
                </div>
            </div>

            <div class="flex gap-4">
                <button class="flex-1 btn-primary text-lg py-4">Thêm vào giỏ hàng</button>
                <button class="p-4 rounded-full border border-gray-200 hover:bg-red-50 hover:border-red-200 hover:text-red-500 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                    </svg>
                </button>
            </div>
        </div>
    </div>
</section>
