<section class="py-10 px-8 max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 gap-6">
        <div>
            <h1 class="text-4xl font-bold mb-2">
                <%= search ? `Kết quả cho "${search}"` : 'Cửa hàng Cây cảnh' %>
            </h1>
            <p class="text-gray-500">
                <%= products.length > 0 ? 'Khám phá không gian xanh cho ngôi nhà của bạn' : 'Rất tiếc, chúng tôi không tìm thấy cây nào phù hợp.' %>
            </p>
        </div>
        
        <!-- Filters (Functional) -->
        <div class="flex gap-4 overflow-x-auto pb-2 w-full md:w-auto">
            <a href="/shop" class="px-6 py-2 rounded-full <%= !currentFilters.light ? 'bg-emerald-dark text-white' : 'bg-white border border-gray-200' %> whitespace-nowrap">Tất cả</a>
            <a href="/shop?light=Thấp" class="px-6 py-2 rounded-full <%= currentFilters.light === 'Thấp' ? 'bg-emerald-dark text-white' : 'bg-white border border-gray-200' %> hover:border-emerald-dark transition-colors whitespace-nowrap">Ánh sáng thấp</a>
            <a href="/shop?light=Trung bình" class="px-6 py-2 rounded-full <%= currentFilters.light === 'Trung bình' ? 'bg-emerald-dark text-white' : 'bg-white border border-gray-200' %> hover:border-emerald-dark transition-colors whitespace-nowrap">Ánh sáng trung bình</a>
            <a href="/shop?light=Cao" class="px-6 py-2 rounded-full <%= currentFilters.light === 'Cao' ? 'bg-emerald-dark text-white' : 'bg-white border border-gray-200' %> hover:border-emerald-dark transition-colors whitespace-nowrap">Ánh sáng cao</a>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <% products.forEach(product => { %>
        <div class="group bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500">
            <a href="/shop/<%= product.id %>" class="block relative h-72 overflow-hidden">
                <img src="<%= product.imageUrl %>" alt="<%= product.name %>" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                <div class="absolute top-4 right-4">
                    <button class="p-3 bg-white bg-opacity-80 backdrop-blur-md rounded-full shadow-sm hover:bg-emerald-dark hover:text-white transition-all">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                        </svg>
                    </button>
                </div>
            </a>
            <div class="p-6">
                <div class="flex justify-between items-start mb-2">
                    <div>
                        <span class="text-xs font-semibold text-emerald-600 uppercase tracking-wider"><%= product.category %></span>
                        <h3 class="text-xl font-bold"><%= product.name %></h3>
                    </div>
                </div>
                <div class="flex justify-between items-center mt-6">
                    <span class="text-2xl font-bold text-gray-900"><%= product.price.toLocaleString('vi-VN') %>đ</span>
                    <button class="p-3 bg-gray-100 rounded-2xl hover:bg-emerald-dark hover:text-white transition-all duration-300">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>
        <% }) %>
    </div>
</section>
