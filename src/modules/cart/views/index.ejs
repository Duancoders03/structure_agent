<section class="py-12 px-8 max-w-7xl mx-auto">
    <h1 class="text-4xl font-bold mb-12">Giỏ hàng của bạn</h1>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Cart Items -->
        <div class="lg:col-span-2 space-y-6">
            <% cartItems.forEach(item => { %>
            <div class="flex items-center gap-6 bg-white p-6 rounded-3xl shadow-sm border border-gray-100">
                <div class="w-32 h-32 rounded-2xl overflow-hidden flex-shrink-0">
                    <img src="<%= item.imageUrl %>" class="w-full h-full object-cover">
                </div>
                <div class="flex-1">
                    <div class="flex justify-between items-start mb-2">
                        <h3 class="text-xl font-bold"><%= item.name %></h3>
                        <button class="text-gray-400 hover:text-red-500 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                        </button>
                    </div>
                    <div class="flex justify-between items-center mt-4">
                        <div class="flex items-center border border-gray-200 rounded-xl overflow-hidden">
                            <button class="px-4 py-2 hover:bg-gray-100">-</button>
                            <span class="px-4 font-bold"><%= item.quantity %></span>
                            <button class="px-4 py-2 hover:bg-gray-100">+</button>
                        </div>
                        <span class="text-xl font-bold text-emerald-dark"><%= (item.price * item.quantity).toLocaleString('vi-VN') %>đ</span>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>

        <!-- Summary -->
        <div class="lg:col-span-1">
            <div class="glass p-8 sticky top-32">
                <h2 class="text-2xl font-bold mb-6">Tổng đơn hàng</h2>
                <div class="space-y-4 mb-8">
                    <div class="flex justify-between text-gray-600">
                        <span>Tạm tính</span>
                        <span><%= subtotal.toLocaleString('vi-VN') %>đ</span>
                    </div>
                    <div class="flex justify-between text-gray-600">
                        <span>Phí vận chuyển</span>
                        <span><%= shipping.toLocaleString('vi-VN') %>đ</span>
                    </div>
                    <div class="border-t border-gray-200 pt-4 flex justify-between text-xl font-bold">
                        <span>Tổng cộng</span>
                        <span class="text-emerald-dark"><%= total.toLocaleString('vi-VN') %>đ</span>
                    </div>
                </div>
                <button class="w-full btn-primary text-lg py-4 mb-4">Thanh toán ngay</button>
                <a href="/shop" class="block text-center text-gray-500 font-medium hover:text-emerald-dark">Tiếp tục mua sắm</a>
            </div>
        </div>
    </div>
</section>
