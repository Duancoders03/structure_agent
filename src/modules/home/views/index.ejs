<!-- Hero Section -->
<section class="relative min-h-[90vh] flex items-center overflow-hidden">
    <!-- Background Elements -->
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(34,197,94,0.15),transparent_50%)] -z-10"></div>
    <div class="absolute top-1/4 -left-20 w-96 h-96 bg-primary-100 rounded-full blur-3xl opacity-30 -z-10 animate-pulse"></div>
    
    <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-12 items-center">
        <div class="animate-fade-in-up">
            <div class="inline-flex items-center gap-2 bg-emerald-50 text-emerald-700 px-4 py-2 rounded-full text-sm font-bold mb-8">
                <span class="flex h-2 w-2 rounded-full bg-emerald-500 animate-ping"></span>
                Sản phẩm mới đã sẵn sàng
            </div>
            <h1 class="text-6xl md:text-7xl font-bold text-gray-900 mb-8 leading-[1.1]">
                Mang <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-600 to-green-500">Sắc Xanh</span> <br>Vào Tâm Hồn
            </h1>
            <p class="text-xl text-gray-600 mb-10 max-w-xl leading-relaxed">
                Nâng tầm không gian sống của bạn với bộ sưu tập thực vật cao cấp, được tuyển chọn tỉ mỉ để thanh lọc không khí và làm đẹp ngôi nhà.
            </p>
            <div class="flex flex-wrap gap-5">
                <a href="/shop" class="btn-primary text-lg px-10 py-4 shadow-xl shadow-emerald-900/20">
                    Mua sắm ngay
                </a>
                <a href="#featured" class="bg-white text-gray-700 border border-gray-200 text-lg px-10 py-4 rounded-full hover:bg-gray-50 transition-all font-bold">
                    Tìm hiểu thêm
                </a>
            </div>
            
            <div class="mt-12 flex items-center gap-6">
                <div class="flex -space-x-3">
                    <img class="w-10 h-10 rounded-full border-2 border-white shadow-sm" src="https://i.pravatar.cc/100?u=1" alt="">
                    <img class="w-10 h-10 rounded-full border-2 border-white shadow-sm" src="https://i.pravatar.cc/100?u=2" alt="">
                    <img class="w-10 h-10 rounded-full border-2 border-white shadow-sm" src="https://i.pravatar.cc/100?u=3" alt="">
                </div>
                <div class="text-sm">
                    <span class="font-bold text-gray-900">4.9/5</span> dựa trên <span class="font-bold text-gray-900">2,000+</span> đánh giá
                </div>
            </div>
        </div>

        <div class="relative lg:block hidden">
            <div class="relative z-10 animate-float">
                <div class="rounded-[3rem] overflow-hidden shadow-2xl">
                    <img src="https://images.unsplash.com/photo-1545241047-6083a3684587?q=80&w=1000" alt="Plant" class="w-full h-auto transform hover:scale-105 transition-transform duration-1000">
                </div>
                
                <!-- Stats Overlay -->
                <div class="absolute -bottom-6 -right-6 bg-white p-6 rounded-3xl shadow-2xl border border-gray-50 animate-float" style="animation-delay: -1s">
                    <div class="text-3xl font-bold text-emerald-600 mb-1">98%</div>
                    <div class="text-xs text-gray-500 font-bold uppercase tracking-wider">Hài lòng</div>
                </div>
            </div>
            
            <!-- Floating Leaf Decor -->
            <div class="absolute -top-10 -left-10 w-32 h-32 bg-emerald-100 rounded-full blur-2xl opacity-60 -z-10"></div>
        </div>
    </div>
</section>

<!-- Featured Products -->
<section id="featured" class="py-24 px-6 max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 gap-6">
        <div>
            <h2 class="text-4xl font-bold text-gray-900 mb-4">Sản phẩm tiêu biểu</h2>
            <p class="text-gray-500">Những lựa chọn tốt nhất để bắt đầu hành trình xanh của bạn</p>
        </div>
        <a href="/shop" class="text-emerald-600 font-bold hover:text-emerald-700 flex items-center gap-2">
            Xem tất cả sản phẩm
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <% 
        const mockPlants = [
            { name: 'Monstera Deliciosa', price: '450.000', img: 'https://images.unsplash.com/photo-1614594975525-e45190c55d0b?q=80&w=500', cat: 'Cây Trong Nhà' },
            { name: 'Snake Plant', price: '250.000', img: 'https://images.unsplash.com/photo-1599591037488-dc79493956a2?q=80&w=500', cat: 'Dễ Chăm Sóc' },
            { name: 'Fiddle Leaf Fig', price: '680.000', img: 'https://images.unsplash.com/photo-1597055181300-e3633a207519?q=80&w=500', cat: 'Phong Thủy' }
        ];
        %>
        <% mockPlants.forEach((plant, index) => { %>
        <div class="group bg-white rounded-3xl overflow-hidden border border-gray-100 hover:shadow-2xl transition-all duration-500">
            <div class="relative h-80 overflow-hidden">
                <img src="<%= plant.img %>" alt="<%= plant.name %>" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
                <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-[10px] font-bold uppercase text-emerald-700 tracking-wider">
                    <%= plant.cat %>
                </div>
            </div>
            <div class="p-6">
                <h3 class="text-xl font-bold text-gray-900 mb-2"><%= plant.name %></h3>
                <div class="flex justify-between items-center mb-6">
                    <span class="text-2xl font-bold text-emerald-700"><%= plant.price %>đ</span>
                    <div class="flex text-yellow-400 text-xs">
                        ★★★★★
                    </div>
                </div>
                <button class="w-full py-3.5 rounded-2xl bg-gray-900 text-white font-bold hover:bg-emerald-700 transition-all duration-300 flex items-center justify-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                    </svg>
                    Thêm vào giỏ
                </button>
            </div>
        </div>
        <% }) %>
    </div>
</section>



