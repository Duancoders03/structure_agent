<div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
    <table class="w-full text-left">
        <thead class="bg-gray-50 border-b border-gray-100">
            <tr>
                <th class="px-8 py-4 font-bold text-gray-500 text-sm uppercase">Mã Đơn hàng</th>
                <th class="px-8 py-4 font-bold text-gray-500 text-sm uppercase">Khách hàng</th>
                <th class="px-8 py-4 font-bold text-gray-500 text-sm uppercase">Ngày đặt</th>
                <th class="px-8 py-4 font-bold text-gray-500 text-sm uppercase">Trạng thái</th>
                <th class="px-8 py-4 font-bold text-gray-500 text-sm uppercase text-right">Tổng tiền</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
            <% for(let i=1; i<=5; i++) { %>
            <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-8 py-6 font-bold text-emerald-dark">#GL-202<%= i %></td>
                <td class="px-8 py-6">
                    <div class="font-bold">Nguyễn Văn <%= String.fromCharCode(64 + i) %></div>
                    <div class="text-xs text-gray-400">0901 234 56<%= i %></div>
                </td>
                <td class="px-8 py-6 text-gray-500">11/05/2026</td>
                <td class="px-8 py-6">
                    <span class="px-3 py-1 rounded-full bg-blue-100 text-blue-700 text-xs font-bold">Đang xử lý</span>
                </td>
                <td class="px-8 py-6 text-right font-bold">
                    <%= (i * 150000).toLocaleString('vi-VN') %>đ
                </td>
            </tr>
            <% } %>
        </tbody>
    </table>
</div>
