<div class="mb-8 flex items-center justify-between">
    <div>
        <h2 class="text-2xl font-bold text-slate-800">Cập nhật đơn hàng #<%= order.orderNumber %></h2>
        <p class="text-slate-500 text-sm mt-1">Thay đổi trạng thái xử lý và vận chuyển.</p>
    </div>
    <a href="/admin/orders" class="px-6 py-3 rounded-2xl bg-slate-100 text-slate-600 font-bold hover:bg-slate-200 transition-all text-sm">
        Quay lại danh sách
    </a>
</div>

<form action="/admin/orders/<%= order.id %>/edit" method="POST" class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2 space-y-8">
        <!-- Order Details -->
        <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
            <h3 class="text-lg font-bold text-slate-800 mb-6">Thông tin chi tiết</h3>
            <div class="space-y-6">
                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-bold text-slate-400 uppercase tracking-wider mb-2">Khách hàng</label>
                        <div class="font-bold text-slate-800"><%= order.User ? order.User.fullName : 'Ẩn danh' %></div>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-400 uppercase tracking-wider mb-2">Tổng tiền</label>
                        <div class="font-bold text-slate-900 text-xl"><%= order.totalAmount.toLocaleString('vi-VN') %>đ</div>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-400 uppercase tracking-wider mb-2">Địa chỉ giao hàng</label>
                    <textarea name="shippingAddress" rows="3"
                        class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-transparent focus:bg-white focus:border-emerald-500 transition-all outline-none text-sm"><%= order.shippingAddress %></textarea>
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-400 uppercase tracking-wider mb-2">Ghi chú</label>
                    <textarea name="notes" rows="2"
                        class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-transparent focus:bg-white focus:border-emerald-500 transition-all outline-none text-sm"><%= order.notes %></textarea>
                </div>
            </div>
        </div>
    </div>

    <div class="space-y-8">
        <!-- Status Update -->
        <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
            <h3 class="text-lg font-bold text-slate-800 mb-6">Trạng thái đơn hàng</h3>
            <div class="space-y-6">
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Trạng thái xử lý</label>
                    <select name="status"
                        class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-transparent focus:bg-white focus:border-emerald-500 transition-all outline-none text-sm font-semibold text-slate-600 cursor-pointer">
                        <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Chờ xác nhận</option>
                        <option value="processing" <%= order.status === 'processing' ? 'selected' : '' %>>Đang xử lý</option>
                        <option value="shipping" <%= order.status === 'shipping' ? 'selected' : '' %>>Đang giao hàng</option>
                        <option value="completed" <%= order.status === 'completed' ? 'selected' : '' %>>Đã hoàn thành</option>
                        <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Đã hủy</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Thanh toán</label>
                    <select name="paymentStatus"
                        class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-transparent focus:bg-white focus:border-emerald-500 transition-all outline-none text-sm font-semibold text-slate-600 cursor-pointer">
                        <option value="unpaid" <%= order.paymentStatus === 'unpaid' ? 'selected' : '' %>>Chưa thanh toán</option>
                        <option value="paid" <%= order.paymentStatus === 'paid' ? 'selected' : '' %>>Đã thanh toán</option>
                        <option value="refunded" <%= order.paymentStatus === 'refunded' ? 'selected' : '' %>>Đã hoàn tiền</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
            <button type="submit" class="w-full btn-primary py-5 rounded-2xl text-lg">
                Cập nhật đơn hàng
            </button>
        </div>
    </div>
</form>
