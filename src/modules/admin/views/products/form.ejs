<div class="mb-8 flex items-center justify-between">
    <div>
        <h2 class="text-2xl font-bold text-slate-800"><%= isEdit ? 'Chỉnh sửa sản phẩm' : 'Thêm sản phẩm mới' %></h2>
        <p class="text-slate-500 text-sm mt-1">Vui lòng điền đầy đủ thông tin sản phẩm bên dưới.</p>
    </div>
    <a href="/admin/products" class="px-6 py-3 rounded-2xl bg-slate-100 text-slate-600 font-bold hover:bg-slate-200 transition-all text-sm">
        Quay lại danh sách
    </a>
</div>

<form action="<%= isEdit ? '/admin/products/' + product.id + '/edit' : '/admin/products/create' %>" method="POST" class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2 space-y-8">
        <!-- Basic Info -->
        <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
            <h3 class="text-lg font-bold text-slate-800 mb-6">Thông tin cơ bản</h3>
            <div class="space-y-6">
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Tên sản phẩm *</label>
                    <input type="text" name="name" value="<%= isEdit ? product.name : '' %>" required
                        class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-transparent focus:bg-white focus:border-emerald-500 transition-all outline-none text-sm">
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Mô tả sản phẩm</label>
                    <textarea name="description" rows="6"
                        class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-transparent focus:bg-white focus:border-emerald-500 transition-all outline-none text-sm"><%= isEdit ? product.description : '' %></textarea>
                </div>
            </div>
        </div>

        <!-- Pricing & Stock -->
        <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
            <h3 class="text-lg font-bold text-slate-800 mb-6">Giá & Tồn kho</h3>
            <div class="grid grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Giá bán (VNĐ) *</label>
                    <input type="number" name="price" value="<%= isEdit ? product.price : '' %>" required
                        class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-transparent focus:bg-white focus:border-emerald-500 transition-all outline-none text-sm">
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Số lượng tồn kho *</label>
                    <input type="number" name="stock" value="<%= isEdit ? product.stock : 0 %>" required
                        class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-transparent focus:bg-white focus:border-emerald-500 transition-all outline-none text-sm">
                </div>
            </div>
        </div>

        <!-- Care Instructions -->
        <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
            <h3 class="text-lg font-bold text-slate-800 mb-6">Hướng dẫn chăm sóc (JSON)</h3>
            <div>
                <textarea name="careInstructions" rows="4" placeholder='{"light": "Bóng râm", "water": "1 lần/tuần"}'
                    class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-transparent focus:bg-white focus:border-emerald-500 transition-all outline-none text-sm font-mono"><%= isEdit ? JSON.stringify(product.careInstructions, null, 2) : '' %></textarea>
            </div>
        </div>
    </div>

    <div class="space-y-8">
        <!-- Organization -->
        <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
            <h3 class="text-lg font-bold text-slate-800 mb-6">Phân loại</h3>
            <div class="space-y-6">
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Danh mục *</label>
                    <select name="categoryId" required
                        class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-transparent focus:bg-white focus:border-emerald-500 transition-all outline-none text-sm font-semibold text-slate-600 cursor-pointer">
                        <% categories.forEach(cat => { %>
                            <option value="<%= cat.id %>" <%= (isEdit && product.categoryId === cat.id) ? 'selected' : '' %>><%= cat.name %></option>
                        <% }) %>
                    </select>
                </div>
            </div>
        </div>

        <!-- Media -->
        <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
            <h3 class="text-lg font-bold text-slate-800 mb-6">Hình ảnh</h3>
            <div class="space-y-6">
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">URL Hình ảnh</label>
                    <input type="text" name="imageUrl" value="<%= isEdit ? product.imageUrl : '' %>"
                        class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-transparent focus:bg-white focus:border-emerald-500 transition-all outline-none text-sm">
                </div>
                <% if (isEdit && product.imageUrl) { %>
                    <div class="relative group rounded-2xl overflow-hidden border border-slate-100">
                        <img src="<%= product.imageUrl %>" class="w-full h-48 object-cover group-hover:scale-110 transition-transform duration-700">
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Action -->
        <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
            <button type="submit" class="w-full btn-primary py-5 rounded-2xl text-lg">
                <%= isEdit ? 'Lưu thay đổi' : 'Đăng sản phẩm' %>
            </button>
        </div>
    </div>
</form>
