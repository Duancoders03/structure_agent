<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
    <div class="card-premium p-6 border-none bg-white">
        <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 bg-emerald-100 text-emerald-600 rounded-2xl flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
            </div>
            <div>
                <div class="text-xs font-bold text-slate-400 uppercase tracking-wider">Tổng Sản phẩm</div>
                <div class="text-2xl font-bold text-slate-900"><%= stats.totalProducts %></div>
            </div>
        </div>
        <div class="flex items-center gap-2 text-emerald-600 text-sm font-bold">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
            <span>+12.5%</span>
            <span class="text-slate-400 font-medium text-xs">tháng này</span>
        </div>
    </div>

    <div class="card-premium p-6 border-none bg-white">
        <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 bg-blue-100 text-blue-600 rounded-2xl flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                </svg>
            </div>
            <div>
                <div class="text-xs font-bold text-slate-400 uppercase tracking-wider">Đơn hàng mới</div>
                <div class="text-2xl font-bold text-slate-900"><%= stats.totalOrders %></div>
            </div>
        </div>
        <div class="flex items-center gap-2 text-blue-600 text-sm font-bold">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
            <span>+8.2%</span>
            <span class="text-slate-400 font-medium text-xs">tuần này</span>
        </div>
    </div>

    <div class="card-premium p-6 border-none bg-white">
        <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 bg-purple-100 text-purple-600 rounded-2xl flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <div>
                <div class="text-xs font-bold text-slate-400 uppercase tracking-wider">Doanh thu</div>
                <div class="text-2xl font-bold text-slate-900"><%= stats.totalRevenue %></div>
            </div>
        </div>
        <div class="flex items-center gap-2 text-emerald-600 text-sm font-bold">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
            <span>+24%</span>
            <span class="text-slate-400 font-medium text-xs">quý này</span>
        </div>
    </div>

    <div class="card-premium p-6 border-none bg-white">
        <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 bg-orange-100 text-orange-600 rounded-2xl flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
            </div>
            <div>
                <div class="text-xs font-bold text-slate-400 uppercase tracking-wider">Khách hàng</div>
                <div class="text-2xl font-bold text-slate-900"><%= stats.newCustomers %></div>
            </div>
        </div>
        <div class="flex items-center gap-2 text-orange-600 text-sm font-bold">
            <span class="text-slate-400 font-medium text-xs">Mục tiêu đạt 85%</span>
        </div>
    </div>
</div>

<div class="bg-white rounded-[2rem] border border-slate-100 p-8 shadow-sm">
    <div class="flex justify-between items-center mb-10">
        <h3 class="text-xl font-bold text-slate-800">Hoạt động gần đây</h3>
        <button class="text-sm font-bold text-emerald-600 hover:text-emerald-700 transition-colors">Xem tất cả</button>
    </div>
    <div class="space-y-6">
        <% for(let i=1; i<=5; i++) { %>
        <div class="flex items-center justify-between pb-6 border-b border-slate-50 last:border-0 last:pb-0 group">
            <div class="flex items-center gap-5">
                <div class="w-14 h-14 bg-slate-50 rounded-[1.25rem] flex items-center justify-center text-2xl group-hover:bg-emerald-50 transition-colors duration-500">
                    🌿
                </div>
                <div>
                    <div class="font-bold text-slate-800 group-hover:text-emerald-700 transition-colors">Đơn hàng #GL-202<%= i %></div>
                    <div class="text-sm text-slate-400">Khách hàng: Nguyễn Văn A</div>
                </div>
            </div>
            <div class="text-right">
                <div class="font-bold text-slate-900 text-lg">540.000đ</div>
                <div class="text-xs text-slate-400">2 giờ trước</div>
            </div>
        </div>
        <% } %>
    </div>
</div>

